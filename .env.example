# Copy to .env and edit for your deployment.
# Most values have sensible defaults in docker-compose.yml.

# ---------- Backend ----------
NODE_ENV=production
MONGO_URI=mongodb://mongo:27017/pathguard
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:8080
MAX_FILE_SIZE_MB=5

ADMIN_EMAILS=

# ---------- Frontend (build-time) ----------
# Leave VITE_API_URL empty when running behind the bundled nginx reverse proxy.
VITE_API_URL=

# City configuration — see docs/DEPLOY_FOR_YOUR_CITY.md.
VITE_CITY_NAME=Mumbai
VITE_CITY_LAT=19.076
VITE_CITY_LNG=72.8777
VITE_CITY_ZOOM=12
VITE_CITY_LOCALE=en
VITE_CITY_OSM_BBOX=

VITE_MODULE3_ENABLED=true

# ---------- Compose ----------
CLIENT_PORT=8080
