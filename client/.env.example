# ---------- Backend API URL ----------
# WHERE: Origin (scheme + host[, :port]) of the deployed PathGuard API.
# WHEN to set what:
#   - Local dev (Vite + local server):      leave empty (Vite dev proxy)
#   - Local dev (no proxy):                 http://localhost:5000
#   - Production (Render + GitHub Pages):   https://pathguard-api.onrender.com
#                                           (use your actual Render URL)
#
# If you deploy the frontend to GitHub Pages and forget to set this in
# the workflow secrets, the UI shows a fail-fast banner at the top of
# the page and POSTs fail with HTTP 405 from Pages.
#
# See docs/DEPLOYMENT.md §4 for the end-to-end wiring.
VITE_API_URL=

# ---------- City configuration ----------
# See docs/DEPLOY_FOR_YOUR_CITY.md for guidance.
VITE_CITY_NAME=Mumbai
VITE_CITY_LAT=19.076
VITE_CITY_LNG=72.8777
VITE_CITY_ZOOM=12
VITE_CITY_LOCALE=en
# Optional: 'minLng,minLat,maxLng,maxLat' used by OSM-import tooling.
VITE_CITY_OSM_BBOX=

# ---------- Module 3 toggles ----------
# Frontend mirror of the server's MODULE_3_ENABLED. Server is
# authoritative — this only controls whether the UI exposes M3 entry
# points. See docs/MODULE_3_DEPLOYMENT_CHECKLIST.md before flipping ON.
VITE_MODULE3_ENABLED=true
VITE_MODULE3_QUICK_EXIT_URL=https://www.google.com/search?q=weather
