# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB - use MongoDB Atlas connection string in production
MONGO_URI=mongodb://127.0.0.1:27017/pathguard

# Python analytics microservice
ANALYTICS_URL=http://localhost:8000
ANALYTICS_TIMEOUT_MS=20000

# JWT secret - generate a strong random string for production
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - comma-separated list of allowed origins
CLIENT_URL=http://localhost:5173

# File upload limits
MAX_FILE_SIZE_MB=5

# Route planner — OpenStreetMap Overpass API endpoint(s), comma-separated.
# Leave unset to use the public Overpass instances. Point at a self-hosted
# instance for restricted networks or higher rate limits.
OVERPASS_URL=

# AI image analysis — modular Vision-Language-Model provider.
# heuristic (default, no key) | anthropic | openai | gemini. See docs/VISION.md.
VISION_PROVIDER=heuristic
VISION_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=      # for VISION_PROVIDER=anthropic (also: npm i @anthropic-ai/sdk)
# OPENAI_API_KEY=         # for VISION_PROVIDER=openai
# GEMINI_API_KEY=         # for VISION_PROVIDER=gemini
