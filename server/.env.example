# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB - use MongoDB Atlas connection string in production
MONGO_URI=mongodb://127.0.0.1:27017/pathguard

# Python analytics microservice
ANALYTICS_URL=http://localhost:8000
ANALYTICS_TIMEOUT_MS=20000

# JWT secret - generate a strong random string for production
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - comma-separated list of allowed origins
CLIENT_URL=http://localhost:5173

# File upload limits
MAX_FILE_SIZE_MB=5

# Route planner — OpenStreetMap Overpass API endpoint(s), comma-separated.
# Leave unset to use the public Overpass instances. Point at a self-hosted
# instance for restricted networks or higher rate limits.
OVERPASS_URL=
